// module/post/init.go
package post

import (
	"github.com/gin-gonic/gin"
	"gorm.io/gorm"
	"{{.ModuleName}}/shared/mod"
)

var _ mod.Module = (*Module)(nil)

type Module struct {
	Service *Service
	handler *Handler
}

func New(db *gorm.DB) *Module {
	repo := NewRepository(db)
	svc := NewService(repo)
	h := NewHandler(svc)

	return &Module{
		Service: svc,
		handler: h,
	}
}

func (m *Module) RegisterRoutes(r *gin.RouterGroup) {
	m.handler.Routes(r)
}